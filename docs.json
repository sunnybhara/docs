{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Developer Platform",
  "colors": {
    "primary": "#059669",
    "light": "#10b981",
    "dark": "#059669"
  },
  "logo": {
    "light": "/logo/nawa-light.svg",
    "dark": "/logo/nawa-dark.svg"
  },
  "favicon": "/logo/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "errors",
              "rate-limits",
              "billing",
              "webhooks"
            ]
          },
          {
            "group": "Changelog",
            "pages": [
              "changelog"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/classify",
              "api-reference/rubric-classify",
              "api-reference/comments-reply",
              "api-reference/feedback",
              "api-reference/comments-list",
              "api-reference/analytics",
              "api-reference/usage",
              "api-reference/health",
              "api-reference/calibration",
              "api-reference/webhook-manage"
            ]
          }
        ]
      },
      {
        "tab": "SDKs",
        "groups": [
          {
            "group": "SDKs",
            "pages": [
              "sdks/typescript",
              "sdks/python"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Guides",
            "pages": [
              "guides/arabic-dialect-detection",
              "guides/webhook-integration",
              "guides/batch-processing"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Status",
          "href": "https://status.trynawa.com",
          "icon": "signal-bars"
        }
      ]
    }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Open Console",
      "href": "https://trynawa.com/developers/keys"
    }
  },
  "openapi": "openapi.yaml",
  "api": {
    "baseUrl": "https://api.trynawa.com",
    "auth": {
      "method": "bearer",
      "name": "Authorization"
    },
    "playground": {
      "mode": "simple"
    },
    "examples": {
      "prefill": true,
      "languages": ["curl", "python", "javascript"]
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/sunnybhara",
      "linkedin": "https://www.linkedin.com/company/nawaai",
      "x": "https://x.com/try_nawa"
    }
  },
  "redirects": [
    {
      "source": "/dashboard",
      "destination": "/quickstart"
    },
    {
      "source": "/dashboard/billing",
      "destination": "/billing"
    },
    {
      "source": "/dashboard/webhooks",
      "destination": "/webhooks"
    }
  ],
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  },
  "analytics": {
    "posthog": {
      "apiKey": "placeholder_posthog_key"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "mcp",
      "cursor"
    ]
  }
}